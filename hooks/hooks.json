{
  "description": "Prompt Craft — automatic prompt capture on git push and gh pr create",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/skills/prompt-review/hooks/prompt-review-hook.sh\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
